{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Monocle",
  "version": "0.5.0",
  "identifier": "com.mcanulty.monocle",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Monocle",
        "width": 900,
        "height": 700,
        "minWidth": 400,
        "minHeight": 300,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "mimeType": "text/markdown",
        "role": "Viewer",
        "description": "Markdown Document"
      }
    ]
  }
}
